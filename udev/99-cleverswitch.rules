# CleverSwitch udev rules
# Grants the logged-in user access to the Logitech Bolt receiver's HID++ interface
# without requiring root privileges.
#
# Install:
#   sudo cp 99-cleverswitch.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
#   Unplug and replug the Bolt receiver.

# Logitech Bolt receiver (0xC548)
# TAG+="uaccess" grants access to the physically logged-in user (systemd/logind)
# Fallback: GROUP="plugdev", MODE="0660" (add your user to the plugdev group)
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="c548", TAG+="uaccess", GROUP="plugdev", MODE="0660"
